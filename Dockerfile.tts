# edge-tts microservice (FastAPI). Implementation in services/tts is delivered
# in the TTS phase; this Dockerfile is the Coolify-ready shell.
FROM python:3.12-slim
WORKDIR /app
COPY services/tts/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt || echo "requirements wired up in TTS phase"
COPY services/tts ./
EXPOSE 8000
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
