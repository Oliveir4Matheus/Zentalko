{
  "name": "learn-english",
  "version": "0.1.0",
  "private": true,
  "description": "PWA para brasileiros aprenderem inglês (Next.js 15 + tRPC + Prisma + FSRS).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.50",
    "@ai-sdk/google": "^0.0.50",
    "@ai-sdk/openai": "^0.0.70",
    "@auth/prisma-adapter": "^2.7.0",
    "@prisma/client": "^5.20.0",
    "@tanstack/react-query": "^5.59.0",
    "@trpc/client": "^11.0.0-rc.500",
    "@trpc/react-query": "^11.0.0-rc.500",
    "@trpc/server": "^11.0.0-rc.500",
    "ai": "^3.4.0",
    "bcryptjs": "^2.4.3",
    "epub2": "^3.0.2",
    "fast-xml-parser": "^5.5.11",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "minio": "^8.0.0",
    "next": "^15.0.0",
    "next-auth": "5.0.0-beta.22",
    "next-intl": "^3.20.0",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-fsrs": "^4.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.27",
    "msw": "^2.4.0",
    "postcss": "^8.5.9",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.19",
    "ts-fsrs": "^4.4.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
