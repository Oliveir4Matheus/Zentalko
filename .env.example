# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://learnenglish:learnenglish@db:5432/learnenglish

# ─── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-in-production-min-32-chars
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── BYOK crypto (AES-256-GCM key for encrypting user LLM keys) ───────────────
# Must be 32 bytes when utf-8 encoded (or set via base64 in a longer form).
# Generate with: openssl rand -base64 32
# WARNING: losing this key means all stored user API keys become unrecoverable.
BYOK_ENCRYPTION_KEY=32byteslongproductionkey_padpad__

# ─── Storage (MinIO / S3) ─────────────────────────────────────────────────────
STORAGE_ENDPOINT=http://storage:9000
STORAGE_ACCESS_KEY=learnenglish
STORAGE_SECRET_KEY=learnenglish
STORAGE_BUCKET=learnenglish

# ─── TTS microservice ─────────────────────────────────────────────────────────
TTS_URL=http://tts:8000

# ─── Test environment (integration/e2e) ───────────────────────────────────────
# DATABASE_URL=postgres://test:test@localhost:5432/learnenglish_test
# AUTH_SECRET=testsecret
# BYOK_ENCRYPTION_KEY=32byteslongtestkey_padpadpadpadpa
